        {
          "name": "Get My Rank - Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/my-rank/month",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "my-rank", "month"]
            }
          }
        }
      ]
    },
    {
      "name": "Target Management (Admin)",
      "item": [
        {
          "name": "Set Monthly Target with 3 Tiers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salespersonId\": 1,\n  \"month\": 7,\n  \"year\": 2026,\n  \"targetAmount\": 55000,\n  \"targetTier1\": 45000,\n  \"targetTier2\": 55000,\n  \"targetTier3\": 65000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/salesperson/targets",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson", "targets"]
            }
          }
        },
        {
          "name": "Get Target by Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson/targets?salespersonId={{salesperson_id}}&month=6&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson", "targets"],
              "query": [
                {
                  "key": "salespersonId",
                  "value": "{{salesperson_id}}"
                },
                {
                  "key": "month",
                  "value": "6"
                },
                {
                  "key": "year",
                  "value": "2026"
                }
              ]
            }
          }
        },
        {
          "name": "Recalculate Achievements",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson/targets/recalculate?month=6&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson", "targets", "recalculate"],
              "query": [
                {
                  "key": "month",
                  "value": "6"
                },
                {
                  "key": "year",
                  "value": "2026"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Salesperson CRUD (Admin)",
      "item": [
        {
          "name": "Get All Salespersons",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Get Salesperson by Employee Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson/by-employee-code/SP001",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson", "by-employee-code", "SP001"]
            }
          }
        }
      ]
    }
  ]
}
