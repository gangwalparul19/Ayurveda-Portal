{
  "info": {
    "name": "Sales Performance API Tests",
    "description": "Test collection for Salesperson Dashboard and Leaderboard APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "salesperson_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "salesperson_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login as Salesperson (SP001)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('salesperson_token', jsonData.accessToken);",
                  "    console.log('Salesperson token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sp001\",\n  \"password\": \"Sales@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('admin_token', jsonData.accessToken);",
                  "    console.log('Admin token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Salesperson Dashboard",
      "item": [
        {
          "name": "Get Complete Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}"]
            }
          }
        },
        {
          "name": "Get Today's Performance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/today",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "today"]
            }
          }
        },
        {
          "name": "Get Week Performance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/week",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "week"]
            }
          }
        },
        {
          "name": "Get Month Performance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/month",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "month"]
            }
          }
        },
        {
          "name": "Get Target Achievement",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/target-achievement",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "target-achievement"]
            }
          }
        },
        {
          "name": "Get Performance Trend (Last 7 Days)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/trend",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "{{salesperson_id}}", "trend"]
            }
          }
        }
      ]
    },
    {
      "name": "Leaderboards",
      "item": [
        {
          "name": "Get Weekly Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/leaderboard/week",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "leaderboard", "week"]
            }
          }
        },
        {
          "name": "Get Monthly Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/leaderboard/month",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "leaderboard", "month"]
            }
          }
        },
        {
          "name": "Get Quarterly Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/leaderboard/quarter",
              "host": ["{{baseUrl}}"],
              "path": ["salesperson-dashboard", "leaderboard", "quarter"]
            }
          }
        },
        {
          "name": "Get My Rank - Week",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{salesperson_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/salesperson-dashboard/{{salesperson_id}}/my-rank/week",
              "host": ["{{baseUrl}}"],
